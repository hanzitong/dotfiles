{
    "security.workspace.trust.untrustedFiles": "open",
    "redhat.telemetry.enabled": false,
    "window.title": "${activeEditorLong}",
    "window.density.editorTabHeight": "compact",
    "explorer.confirmDragAndDrop": false,
    "editor.minimap.enabled": false,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.semanticHighlighting.enabled": "configuredByTheme",
    "editor.editContext": false,
    "editor.glyphMargin": false,
    "editor.folding": false,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    // "console": "integratedTerminal",
    // "workbench.colorTheme": "Visual Studio Dark - C++",
    // "workbench.colorTheme": "Dark Modern",
    "workbench.edigor.labelFormat": "long",
    "workbench.editor.warpTabs": true,
    "workbench.panel.defaultLocation": "right",
    "workbench.tree.renderIndentGuides": "always",
    "terminal.integrated.cursorStyle": "block",
    "terminal.integrated.cursorBlinking": true,
    "workbench.colorCustomizations": {
        // "editor.background": "#30383f7d",
        "editor.background": "#282f3c",
        "editorGroup.emptyBackground": "#746e6e",
        "sideBar.background": "#282f3c",
        "statusBar.background": "#36404b",
        "statusBar.noFolderBackground": "#5c6a7a",
        // "terminal.background": "#242527",
        "terminal.background": "#282f3c",
        "terminal.foreground": "#a6aaac",
        "tree.indentGuidesStroke": "#3dd9f5",
        "tree.inactiveIndentGuidesStroke": "#47688f"
    },

    "git.openRepositoryInParentFolders": "always",
    "git.confirmSync": false,
    "git.autofetch": true,

    "vim.foldfix": true,

    "files.associations": {
        "*.world": "xml",
        "*.urdf": "xml",
        "*.xacro": "xml",
        "*.sdf": "xml",
        "*.srdf": "xml"
    },

    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "cline.vsCodeLmModelSelector": {},
    "claudeCode.preferredLocation": "panel",

    "cmake.showOptionsMovedNotification": false,

    "python.defaultInterpreterPath": "/bin/python3",
    "python.createEnvironment.trigger": "off",
    "jupyter.askForKernelRestart": false,

    "hediet.vscode-drawio.resizeImages": null,
    // "hediet.vscode-drawio.autoExport": true,
    // "hediet.vscode-drawio.exportFormat": "svg",
    // "hediet.vscode-drawio.exportFileExtension": ".svg",
    // "hediet.vscode-drawio.exportPath": "./"
    "mermaidChart.showGenerateDiagramCodeLens": false,
 
}
