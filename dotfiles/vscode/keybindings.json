
[
    {
        "key": "ctrl+t",
        "command": "workbench.action.terminal.focus",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+alt+s",
        "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
        "when": "!isAuxiliaryWindowFocusedContext"
    },

    {
        "key": "ctrl+l",    // "key": "ctrl+escape",
        "command": "claude-vscode.focus",
        "when": "editorTextFocus && !config.claudeCode.useTerminal"
    },
    {
        "key": "ctrl+escape",    // "key": "alt+k",
        "command": "claude-vscode.insertAtMention",
        "when": "editorTextFocus"
    },
   
]


